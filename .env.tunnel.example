# Phase 1 部署 env 模板 — Cloudflare Quick Tunnel 架构
#
# 用法：
#   cp .env.tunnel.example .env.tunnel
#   chmod 600 .env.tunnel
#   vim .env.tunnel    # 填密码 / LLM key / CORS_ORIGIN
#
# 比 .env.production.example 少 4 项：DOMAIN / ACME_EMAIL 不需要（Cloudflare 提供 SSL）

# ── 数据库密码 ─────────────────────────────────────────────────────────────
# 生成：openssl rand -base64 32
DB_PASSWORD=change-me-to-a-strong-random-password

# ── JWT 签名 secret ──────────────────────────────────────────────────────────
# 生成：openssl rand -base64 48（≥ 16 字符）
JWT_SECRET=change-me-min-16-chars-please-rotate-regularly

# ── CORS 白名单 ─────────────────────────────────────────────────────────────
# Vercel 部署后会知道准确 URL（如 https://idea-maker-sissi.vercel.app）
# Phase 1 临时：先用通配 `*` 调通，再改成准确 URL
# Phase 1 最终：填 Vercel 真实 URL
CORS_ORIGIN=*

# ── LLM Provider（智谱 GLM 示例） ──────────────────────────────────────────
LLM_API_KEY=your-glm-key-here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-flash

# ── Tavily web search（可选） ────────────────────────────────────────────
# 不填则 search_web tool 降级返回空
TAVILY_API_KEY=
