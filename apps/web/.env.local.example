# ─── 本地开发环境变量 ─────────────────────────────────────────────────────────
# 复制此文件为 .env.local，填入真实值后重启 dev server

# PostgreSQL + pgvector（Storage Stage + Retrieval Stage 必需）
# docker compose up postgres 启动后默认值：
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag

# ─── LLM Provider（Chat Completions）─────────────────────────────────────────
# 支持任何 OpenAI-compatible API，下方给出 OpenAI 和 Qwen 两种示例

# 方案 A：OpenAI
# OPENAI_API_KEY=sk-xxx

# 方案 B：Qwen / DashScope（OpenAI-compatible 模式）
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ─── Embedding Provider ────────────────────────────────────────────────────────
# 可以与 LLM 使用不同的 provider / model

# 方案 A：OpenAI
# OPENAI_API_KEY=sk-xxx（与上方共用）

# 方案 B：Qwen text-embedding-v4
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSION=1024

# HuggingFace TEI 服务（本地推理替代方案）
# HF_TEI_ENDPOINT=http://localhost:8080

# pymupdf 微服务（PDF 精确提取，可选）
# docker compose up pymupdf 启动后：
PYMUPDF_SERVICE_URL=http://localhost:8001
