# API 本地开发：复制为 apps/api/.env，填入真实凭据后执行 pnpm --filter @harness/api dev。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag
# PostgreSQL 连接池：2C/2GB 单实例默认最多 10 条，空闲连接 30 秒后回收。
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
# 官网正文批处理：减少 Embedding HTTP 往返和 PostgreSQL INSERT 往返。
WEBSITE_EMBEDDING_BATCH_SIZE=16
WEBSITE_RAG_INSERT_BATCH_SIZE=50
JWT_SECRET=replace-with-a-random-secret-at-least-16-characters
CORS_ORIGIN=http://localhost:3000

# 任意 OpenAI-compatible LLM；没有 LLM key 时仅不能运行真实生成/评测。
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 中文优先 embedding。没有 embedding key 时官网正文仍可用 BM25 检索。
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
# PostgreSQL 后台任务 worker（Product Brief / Campaign）
JOB_CONCURRENCY_DEFAULT=1
JOB_CONCURRENCY_BRIEF_EXTRACT=1
JOB_CONCURRENCY_CAMPAIGN_GENERATE=1
JOB_LEASE_MS=60000
JOB_HEARTBEAT_MS=20000
JOB_POLL_MS=500
JOB_SHUTDOWN_GRACE_MS=10000
