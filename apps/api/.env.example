# API 本地开发：复制为 apps/api/.env，填入真实凭据后执行 pnpm --filter @harness/api dev。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag
JWT_SECRET=replace-with-a-random-secret-at-least-16-characters
CORS_ORIGIN=http://localhost:3000

# 任意 OpenAI-compatible LLM；没有 LLM key 时仅不能运行真实生成/评测。
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 中文优先 embedding。没有 embedding key 时官网正文仍可用 BM25 检索。
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
