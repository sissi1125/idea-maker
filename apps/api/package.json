{
  "name": "@harness/api",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS 后端：feat-100.3 起承接 RAG pipeline 端点；当前仅 health 端点占位",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:once": "ts-node -r tsconfig-paths/register src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "ts-node -r tsconfig-paths/register -r dotenv/config scripts/eval.ts",
    "eval:content": "ts-node -r tsconfig-paths/register scripts/content-eval.ts",
    "bench:sources": "tsx scripts/benchmark-sources-batching.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.0",
    "@harness/rag-core": "workspace:^",
    "@harness/shared-types": "workspace:^",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^8.0.0",
    "ai": "^4.3.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "openai": "^6.38.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "0.34.5",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
