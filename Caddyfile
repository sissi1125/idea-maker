# Caddy 生产配置 — feat-013.5 阿里云 ECS
#
# 自动 HTTPS：Caddy 启动后会自动从 Let's Encrypt 申请证书
#   前提：DOMAIN / api.DOMAIN 的 DNS A 记录已指到 ECS 公网 IP
#
# 两个站点：
#   ${DOMAIN}     → web:3000   （Next.js）
#   api.${DOMAIN} → api:3001   （NestJS，含 SSE）

{
  # 全局：用 .env 里的 ACME_EMAIL 注册 Let's Encrypt
  email {$ACME_EMAIL}

  # 启用 HTTP/3（QUIC over UDP 443）
  servers {
    protocols h1 h2 h3
  }
}

# ── 前端 Web ──────────────────────────────────────────────────────────────
{$DOMAIN} {
  encode gzip zstd

  # 直连内部 web service
  reverse_proxy web:3000 {
    # 透传真实 IP（前端用不到，但留着调试）
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-Proto {scheme}
  }

  # 静态资源缓存 1 年（Next.js 文件名带 hash，安全）
  @nextstatic path /_next/static/* /static/*
  header @nextstatic Cache-Control "public, max-age=31536000, immutable"

  # 简单访问日志
  log {
    output stdout
    format console
  }
}

# ── 后端 API（含 SSE） ────────────────────────────────────────────────────
api.{$DOMAIN} {
  encode gzip zstd

  reverse_proxy api:3001 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-Proto {scheme}

    # SSE 关键配置：禁用缓冲，否则 step/cost 帧会被攒到一起再吐
    # Caddy 默认 flush_interval=-1（立即转发），但显式声明更稳
    flush_interval -1

    # 长连接：SSE 一次 run 可能 60s+
    # transport http {
    #   read_timeout 10m
    # }
  }

  log {
    output stdout
    format console
  }
}

# www 重定向（可选，DNS 配了 www.${DOMAIN} 才生效）
www.{$DOMAIN} {
  redir https://{$DOMAIN}{uri} permanent
}
