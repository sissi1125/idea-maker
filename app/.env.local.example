# ─── 本地开发环境变量 ─────────────────────────────────────────────────────────
# 复制此文件为 .env.local，填入真实值后重启 dev server

# PostgreSQL + pgvector（Storage Stage + Retrieval Stage 必需）
# docker compose up postgres 启动后默认值：
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag

# OpenAI（Embedding Stage / Query Rewrite LLM / Rerank LLM 可选）
# 留空则在 Playground 表单中临时填写，或使用 debug-deterministic embedding
OPENAI_API_KEY=

# HuggingFace TEI 服务（可选，替代 OpenAI embedding / rerank）
# 启动示例：docker run -p 8080:80 ghcr.io/huggingface/text-embeddings-inference:cpu-1.5 --model-id BAAI/bge-small-en-v1.5
HF_TEI_ENDPOINT=

# pymupdf 微服务（PDF 精确提取，可选）
# docker compose up pymupdf 启动后：
PYMUPDF_SERVICE_URL=http://localhost:8001
