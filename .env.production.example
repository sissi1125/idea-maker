# 生产环境变量模板 — feat-013.5 阿里云 ECS 部署
#
# 用法：
#   cp .env.production.example .env.production
#   vim .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# **本文件不进 git**（.gitignore 里已排除 .env.* 模式）

# ── 域名 + ACME ───────────────────────────────────────────────────────────
# 你的生产域名。Caddy 自动从 Let's Encrypt 申请证书。
# DNS 记录需提前配：
#   A    @           → ECS 公网 IP
#   A    api         → ECS 公网 IP
#   A    www         → ECS 公网 IP（可选）
DOMAIN=example.com

# Let's Encrypt 通知邮箱（证书过期前会发邮件）
ACME_EMAIL=you@example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────
# 任意强密码，建议：openssl rand -base64 32
DB_PASSWORD=change-me-to-a-strong-random-password

# ── 鉴权 ──────────────────────────────────────────────────────────────────
# JWT 签名 secret，要求 >= 16 字符
# 建议：openssl rand -base64 48
JWT_SECRET=change-me-min-16-chars-please-rotate-regularly

# ── LLM Provider（BYOK） ────────────────────────────────────────────────────
# 选一组：
#
# 智谱 GLM（推荐，国内访问稳定，本项目实测）：
LLM_API_KEY=your-glm-key-here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-flash
#
# 或 OpenAI：
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
#
# 或 DeepSeek：
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# 或 Qwen / DashScope：
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# ── Embedding ─────────────────────────────────────────────────────────────
# 生产用容器内 ollama（已在 docker-compose.prod.yml 配死）：
#   EMBEDDING_BASE_URL=http://ollama:11434/v1
#   EMBEDDING_MODEL=bge-m3
#   EMBEDDING_DIMENSION=1024
#
# 首次启动后必须 pull 模型：
#   docker compose -f docker-compose.prod.yml exec ollama ollama pull bge-m3

# ── Tavily web search（可选） ────────────────────────────────────────────
# 不填则 search_web tool 降级（返回空 + 友好错误）
TAVILY_API_KEY=
